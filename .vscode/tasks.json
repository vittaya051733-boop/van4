      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/deploy-storage-isolated.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
